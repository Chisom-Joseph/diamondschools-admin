<%- include("../partials/header") %>
<main class="content">
  <div class="container-fluid p-0">

    <div class="mb-3">
      <h1 class="h3 d-inline align-middle">Site Settings</h1>
    </div>

    <div class="row">
      <div class="col-md-12">
        <div class="card">
          <div class="card-header">
            <h5 class="card-title">Site information</h5>
          </div>
          <div class="card-body">
            <form method="POST" action="?action=add">
              <% if(alert.status === "error" && alert.section === "site_settings") { %>
              <div class="alert alert-danger alert-dismissible" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                <div class="alert-message">
                  <strong>Error!</strong> <%- alert.message %>
                </div>
              </div>
              <% } %>
              <% if(alert.status === "success" && alert.section === "site_settings") { %>
              <div class="alert alert-success alert-dismissible" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                <div class="alert-message pr-5">
                  <strong>Sucess!</strong> <%- alert.message %>
                </div>
              </div>
              <% } %>
              <!-- Personal Information -->
              <h4 class="mt-3">Site settings and meta data</h4>
              <div class="row">
                <div class="mb-3 col-md-4">
                  <label class="form-label" for="siteName">Site Name</label>
                  <input type="text" class="form-control" id="siteName" placeholder="Site Name" name="siteName" value="<%= form.siteName %>">
                </div>
                <div class="mb-3 col-md-4">
                  <label class="form-label" for="siteDescription">Site Description</label>
                  <input type="text" class="form-control" id="siteDescription" placeholder="Site Description" name="siteDescription" value="<%= form.siteDescription %>">
                </div>
                <div class="mb-3 col-md-4">
                  <label class="form-label" for="siteEmail">Site Email</label>
                  <input type="email" class="form-control" id="siteEmail" placeholder="Site Email" name="siteEmail" value="<%= form.siteEmail %>">
                </div>
              </div>
              <div class="row">
                <div class="mb-3 col-md-12">
                  <label class="form-label" for="siteKeywords">Site Keywords</label>
                  <textarea class="form-control" id="siteKeywords" name="siteKeywords"><%= form.siteKeywords %></textarea>
                </div>
              </div>

              <!-- Submit Button -->
              <button type="submit" class="btn btn-primary" disabled>Submit</button>
            </form>

          </div>
        </div>
      </div>
    </div>

    <div class="row mt-4">
      <div class="col-md-12">
        <div class="card">
          <div class="card-header">
            <h5 class="card-title">Payment Information</h5>
          </div>
          <div class="card-body">
            <form method="POST" action="?action=update">
              <% if(alert.status === "error" && alert.section === "payment_settings") { %>
              <div class="alert alert-danger alert-dismissible" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                <div class="alert-message">
                  <strong>Error!</strong> <%- alert.message %>
                </div>
              </div>
              <% } %>
              <% if(alert.status === "success" && alert.section === "payment_settings") { %>
              <div class="alert alert-success alert-dismissible" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                <div class="alert-message pr-5">
                  <strong>Sucess!</strong> <%- alert.message %>
                </div>
              </div>
              <% } %>
              <h4 class="mt-3">Enrollment Payment Details</h4>
              <div class="row">
                <div class="mb-2 col-md-6">
                  <label class="form-label" for="description">Description</label>
                  <input id="description" name="description" type="text" class="form-control" value="<%= paymentSettings.description || form.description %>" placeholder="e.g. 2025/2026 ENTRANCE EXAMINATION FORM">
                </div>
                <div class="mb-2 col-md-6">
                  <label class="form-label" for="amount">Amount</label>
                  <input id="amount" name="amount" type="text" class="form-control" value="<%= paymentSettings.amount || form.amount %>" placeholder="e.g. NGN1,500">
                </div>
                <div class="mb-2 col-md-6">
                  <label class="form-label" for="accountNumber">Account Number</label>
                  <input id="accountNumber" name="accountNumber" type="text" class="form-control" value="<%= paymentSettings.accountNumber || form.accountNumber %>" placeholder="e.g. 1228721078">
                </div>
                <div class="mb-2 col-md-6">
                  <label class="form-label" for="accountName">Account Name</label>
                  <input id="accountName" name="accountName" type="text" class="form-control" value="<%= paymentSettings.accountName || form.accountName %>" placeholder="e.g. Diamond Schools Nkpor">
                </div>
                <div class="mb-2 col-md-6">
                  <label class="form-label" for="bankName">Bank Name</label>
                  <input id="bankName" name="bankName" type="text" class="form-control" value="<%= paymentSettings.bankName || form.bankName %>" placeholder="e.g. Zenith Bank">
                </div>
                <div class="mb-2 col-md-6">
                  <label class="form-label" for="accountType">Account Type</label>
                  <input id="accountType" name="accountType" type="text" class="form-control" value="<%= paymentSettings.accountType || form.accountType %>" placeholder="e.g. Savings">
                </div>
              </div>

              <!-- Submit Button -->
              <button type="submit" class="btn btn-primary mt-3">Save Payment Info</button>
            </form>

          </div>
        </div>
      </div>
    </div>


  </div>
</main>

<script>
  const form = JSON.parse('<%- JSON.stringify(form) %>');
</script>
<script src="/js/custom.js"></script>

<%- include("../partials/footer") %>