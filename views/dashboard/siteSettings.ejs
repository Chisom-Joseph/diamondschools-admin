<%- include("../partials/header") %>
<main class="content">
  <div class="container-fluid p-0">

    <div class="mb-3">
      <h1 class="h3 d-inline align-middle">Site Settings</h1>
    </div>

    <div class="row">
      <div class="col-md-12">
        <div class="card">
          <div class="card-header">
            <h5 class="card-title">Site information</h5>
          </div>
          <div class="card-body">
            <form method="POST" action="">
              <% if(alert && alert.status === "error" && alert.section === "site_settings") { %>
              <div class="alert alert-danger alert-dismissible" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                <div class="alert-message">
                  <strong>Error!</strong> <%- alert.message %>
                </div>
              </div>
              <% } %>
              <% if(alert && alert.status === "success" && alert.section === "site_settings") { %>
              <div class="alert alert-success alert-dismissible" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                <div class="alert-message pr-5">
                  <strong>Sucess!</strong> <%- alert.message %>
                </div>
              </div>
              <% } %>
              <!-- Site Information -->
              <h4 class="mt-3">Site Settings and Meta Data</h4>
              <div class="row">
                <div class="mb-3 col-md-6">
                  <label class="form-label" for="name">School/Site Name *</label>
                  <input type="text" class="form-control" id="name" placeholder="e.g. Diamond Schools" name="name" value="<%= form.name || '' %>" required>
                </div>
                <div class="mb-3 col-md-6">
                  <label class="form-label" for="title">Site Title</label>
                  <input type="text" class="form-control" id="title" placeholder="e.g. Diamond Schools - Excellence in Education" name="title" value="<%= form.title || form.name || '' %>">
                </div>
              </div>
              <div class="row">
                <div class="mb-3 col-md-6">
                  <label class="form-label" for="email">Email Address *</label>
                  <input type="email" class="form-control" id="email" placeholder="school@email.com" name="email" value="<%= form.email || '' %>" required>
                </div>
                <div class="mb-3 col-md-6">
                  <label class="form-label" for="phone1">Primary Phone *</label>
                  <input type="text" class="form-control" id="phone1" placeholder="07057430682" name="phone1" value="<%= form.phone1 || '' %>" required>
                </div>
              </div>
              <div class="row">
                <div class="mb-3 col-md-4">
                  <label class="form-label" for="phone2">Secondary Phone</label>
                  <input type="text" class="form-control" id="phone2" placeholder="08026125461" name="phone2" value="<%= form.phone2 || '' %>">
                </div>
                <div class="mb-3 col-md-4">
                  <label class="form-label" for="phone3">Tertiary Phone</label>
                  <input type="text" class="form-control" id="phone3" placeholder="08130331977" name="phone3" value="<%= form.phone3 || '' %>">
                </div>
                <div class="mb-3 col-md-4">
                  <label class="form-label" for="keywords">Site Keywords</label>
                  <input type="text" class="form-control" id="keywords" placeholder="education, school, excellence" name="keywords" value="<%= form.keywords || '' %>">
                </div>
              </div>
              <div class="row">
                <div class="mb-3 col-md-12">
                  <label class="form-label" for="description">Site Description *</label>
                  <textarea class="form-control" id="description" name="description" rows="3" required><%= form.description || '' %></textarea>
                </div>
              </div>
              <div class="row">
                <div class="mb-3 col-md-12">
                  <label class="form-label" for="address">School Address *</label>
                  <textarea class="form-control" id="address" name="address" rows="2" required><%= form.address || '' %></textarea>
                </div>
              </div>
              <div class="row">
                <div class="mb-3 col-md-4">
                  <label class="form-label" for="favicon">Favicon URL</label>
                  <input type="text" class="form-control" id="favicon" placeholder="/assets/img/logo/favicon.png" name="favicon" value="<%= form.favicon || '' %>">
                </div>
                <div class="mb-3 col-md-4">
                  <label class="form-label" for="logo">Logo URL</label>
                  <input type="text" class="form-control" id="logo" placeholder="/assets/img/logo/logo.png" name="logo" value="<%= form.logo || '' %>">
                </div>
                <div class="mb-3 col-md-4">
                  <label class="form-label" for="logoLight">Light Logo URL</label>
                  <input type="text" class="form-control" id="logoLight" placeholder="/assets/img/logo/logo-light.png" name="logoLight" value="<%= form.logoLight || '' %>">
                </div>
              </div>

              <!-- Submit Button -->
              <button type="submit" class="btn btn-primary mt-3">Save Site Settings</button>
            </form>

          </div>
        </div>
      </div>
    </div>

    <div class="row mt-4">
      <div class="col-md-12">
        <div class="card">
          <div class="card-header">
            <h5 class="card-title">Payment Information</h5>
          </div>
          <div class="card-body">
            <form method="POST" action="?action=update">
              <% if(alert && alert.status === "error" && alert.section === "payment_settings") { %>
              <div class="alert alert-danger alert-dismissible" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                <div class="alert-message">
                  <strong>Error!</strong> <%- alert.message %>
                </div>
              </div>
              <% } %>
              <% if(alert && alert.status === "success" && alert.section === "payment_settings") { %>
              <div class="alert alert-success alert-dismissible" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                <div class="alert-message pr-5">
                  <strong>Sucess!</strong> <%- alert.message %>
                </div>
              </div>
              <% } %>
              <h4 class="mt-3">Enrollment Payment Details</h4>
              <div class="row">
                <div class="mb-2 col-md-6">
                  <label class="form-label" for="description">Description</label>
                  <input id="description" name="description" type="text" class="form-control" value="<%= paymentSettings.description || form.description %>" placeholder="e.g. 2025/2026 ENTRANCE EXAMINATION FORM">
                </div>
                <div class="mb-2 col-md-6">
                  <label class="form-label" for="amount">Amount</label>
                  <input id="amount" name="amount" type="text" class="form-control" value="<%= paymentSettings.amount || form.amount %>" placeholder="e.g. NGN1,500">
                </div>
                <div class="mb-2 col-md-6">
                  <label class="form-label" for="accountNumber">Account Number</label>
                  <input id="accountNumber" name="accountNumber" type="text" class="form-control" value="<%= paymentSettings.accountNumber || form.accountNumber %>" placeholder="e.g. 1228721078">
                </div>
                <div class="mb-2 col-md-6">
                  <label class="form-label" for="accountName">Account Name</label>
                  <input id="accountName" name="accountName" type="text" class="form-control" value="<%= paymentSettings.accountName || form.accountName %>" placeholder="e.g. Diamond Schools Nkpor">
                </div>
                <div class="mb-2 col-md-6">
                  <label class="form-label" for="bankName">Bank Name</label>
                  <input id="bankName" name="bankName" type="text" class="form-control" value="<%= paymentSettings.bankName || form.bankName %>" placeholder="e.g. Zenith Bank">
                </div>
                <div class="mb-2 col-md-6">
                  <label class="form-label" for="accountType">Account Type</label>
                  <input id="accountType" name="accountType" type="text" class="form-control" value="<%= paymentSettings.accountType || form.accountType %>" placeholder="e.g. Savings">
                </div>
              </div>

              <!-- Submit Button -->
              <button type="submit" class="btn btn-primary mt-3">Save Payment Info</button>
            </form>

          </div>
        </div>
      </div>
    </div>


  </div>
</main>

<script>
  const form = JSON.parse('<%- JSON.stringify(form) %>');
</script>
<script src="/js/custom.js"></script>

<%- include("../partials/footer") %>