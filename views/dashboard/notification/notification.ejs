<%- include("../../partials/header") %>
<% const audienceLabels = { 'all-students': 'All Students', 'all-aspirants': 'All Aspirants', 'all-teachers': 'All Teachers', 'specific-students': 'Specific Students', 'specific-aspirants': 'Specific Aspirants', 'specific-teachers': 'Specific Teachers' }; %>
<main class="content">
  <div class="container-fluid p-0">

    <div class="mb-3">
      <h1 class="h3 d-inline align-middle">Notifications</h1>
    </div>

    <div class="row">
      <!-- Create Notification -->
      <div class="col-md-8">
        <div class="card">
          <div class="card-header">
            <h5 class="card-title">Create Notification</h5>
          </div>
          <div class="card-body pt-0">
            <form method="POST" action="?action=add">
              <% if(alert.status === "error" && alert.section === "add") { %>
              <div class="alert alert-danger alert-dismissible" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                <div class="alert-message pr-5">
                  <strong>Error!</strong> <%- alert.message %>
                </div>
              </div>
              <% } %>
              <% if(alert.status === "success" && alert.section === "add") { %>
              <div class="alert alert-success alert-dismissible" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                <div class="alert-message pr-5">
                  <strong>Success!</strong> <%- alert.message %>
                </div>
              </div>
              <% } %>
              <div class="row">
                <div class="mb-3 col-md-6">
                  <label class="form-label" for="userType">Recipient Type</label>
                  <select class="form-control" id="userType" name="userType" <%= users.length <= 0 ? "disabled" : "" %>>
                    <% if(users.length > 0) { %>
                    <option disabled selected hidden>Select Recipient Type</option>
                    <% users.map((user) => { %>
                    <option value="<%= user.id %>" <%- formSection === "add" && form.userType === user.id ? "selected" : "" %>><%= user.name %></option>
                    <% }) %>
                    <% } else { %>
                    <option disabled selected hidden>No options found</option>
                    <% } %>
                  </select>
                </div>
                <div class="mb-3 col-md-12" id="studentSelectWrapper" style="display:none;">
                  <label class="form-label">Select Students</label>
                  <input type="text" class="form-control mb-2" id="studentSearch" placeholder="Search by name, reg number, class, gender...">
                  <div class="d-flex align-items-center gap-3 mb-2">
                    <small class="text-muted"><span id="studentSelectedCount">0</span> selected</small>
                    <a href="#" id="studentSelectAll" class="small">Select All</a>
                    <a href="#" id="studentDeselectAll" class="small">Deselect All</a>
                  </div>
                  <div id="studentList" class="border rounded p-2" style="max-height:250px;overflow-y:auto;">
                    <% students.forEach((student) => { %>
                    <div class="searchable-item form-check py-1 px-2 rounded" data-search="<%= (student.firstName + ' ' + (student.middleName || '') + ' ' + student.lastName + ' ' + student.registrationNumber + ' ' + (student.Class ? student.Class.name : '') + ' ' + student.gender).toLowerCase() %>">
                      <input class="form-check-input student-checkbox" type="checkbox" name="userIds" value="<%= student.id %>" id="student-<%= student.id %>">
                      <label class="form-check-label w-100" for="student-<%= student.id %>" style="cursor:pointer;">
                        <strong><%= student.firstName %> <%= student.middleName ? student.middleName + ' ' : '' %><%= student.lastName %></strong>
                        <span class="text-muted ms-2" style="font-size:0.85em;"><%= student.registrationNumber %></span>
                        <% if(student.Class) { %>
                        <span class="badge bg-secondary ms-1"><%= student.Class.name %></span>
                        <% } %>
                        <span class="badge bg-light text-dark ms-1" style="font-size:0.75em;"><%= student.gender %></span>
                      </label>
                    </div>
                    <% }) %>
                    <div id="studentNoResults" class="text-muted text-center py-2" style="display:none;">No students found</div>
                  </div>
                </div>
                <div class="mb-3 col-md-12" id="aspirantSelectWrapper" style="display:none;">
                  <label class="form-label">Select Aspirants</label>
                  <input type="text" class="form-control mb-2" id="aspirantSearch" placeholder="Search by name, exam number, class, gender...">
                  <div class="d-flex align-items-center gap-3 mb-2">
                    <small class="text-muted"><span id="aspirantSelectedCount">0</span> selected</small>
                    <a href="#" id="aspirantSelectAll" class="small">Select All</a>
                    <a href="#" id="aspirantDeselectAll" class="small">Deselect All</a>
                  </div>
                  <div id="aspirantList" class="border rounded p-2" style="max-height:250px;overflow-y:auto;">
                    <% aspirants.forEach((aspirant) => { %>
                    <div class="searchable-item form-check py-1 px-2 rounded" data-search="<%= (aspirant.firstName + ' ' + (aspirant.middleName || '') + ' ' + aspirant.lastName + ' ' + aspirant.examinationNumber + ' ' + (aspirant.Class ? aspirant.Class.name : '') + ' ' + aspirant.gender).toLowerCase() %>">
                      <input class="form-check-input aspirant-checkbox" type="checkbox" name="userIds" value="<%= aspirant.id %>" id="aspirant-<%= aspirant.id %>">
                      <label class="form-check-label w-100" for="aspirant-<%= aspirant.id %>" style="cursor:pointer;">
                        <strong><%= aspirant.firstName %> <%= aspirant.middleName ? aspirant.middleName + ' ' : '' %><%= aspirant.lastName %></strong>
                        <span class="text-muted ms-2" style="font-size:0.85em;"><%= aspirant.examinationNumber %></span>
                        <% if(aspirant.Class) { %>
                        <span class="badge bg-secondary ms-1"><%= aspirant.Class.name %></span>
                        <% } %>
                        <span class="badge bg-light text-dark ms-1" style="font-size:0.75em;"><%= aspirant.gender %></span>
                      </label>
                    </div>
                    <% }) %>
                    <div id="aspirantNoResults" class="text-muted text-center py-2" style="display:none;">No aspirants found</div>
                  </div>
                </div>
                <div class="mb-3 col-md-12" id="teacherSelectWrapper" style="display:none;">
                  <label class="form-label">Select Teachers</label>
                  <input type="text" class="form-control mb-2" id="teacherSearch" placeholder="Search by name, email...">
                  <div class="d-flex align-items-center gap-3 mb-2">
                    <small class="text-muted"><span id="teacherSelectedCount">0</span> selected</small>
                    <a href="#" id="teacherSelectAll" class="small">Select All</a>
                    <a href="#" id="teacherDeselectAll" class="small">Deselect All</a>
                  </div>
                  <div id="teacherList" class="border rounded p-2" style="max-height:250px;overflow-y:auto;">
                    <% teachers.forEach((teacher) => { %>
                    <div class="searchable-item form-check py-1 px-2 rounded" data-search="<%= (teacher.firstName + ' ' + teacher.lastName + ' ' + teacher.email).toLowerCase() %>">
                      <input class="form-check-input teacher-checkbox" type="checkbox" name="userIds" value="<%= teacher.id %>" id="teacher-<%= teacher.id %>">
                      <label class="form-check-label w-100" for="teacher-<%= teacher.id %>" style="cursor:pointer;">
                        <strong><%= teacher.firstName %> <%= teacher.lastName %></strong>
                        <span class="text-muted ms-2" style="font-size:0.85em;"><%= teacher.email %></span>
                      </label>
                    </div>
                    <% }) %>
                    <div id="teacherNoResults" class="text-muted text-center py-2" style="display:none;">No teachers found</div>
                  </div>
                </div>
                <div class="mb-3 col-md-6">
                  <label class="form-label" for="title">Title</label>
                  <input type="text" class="form-control" id="title" placeholder="Title" name="title" value="<%= formSection === "add" ? form.title || "" : "" %>">
                </div>
                <div class="mb-3 col-md-12">
                  <label class="form-label" for="message">Message</label>
                  <textarea class="form-control" id="message" name="message" rows="3" placeholder="Enter notification message"><%= formSection === "add" ? form.message || "" : "" %></textarea>
                </div>
              </div>

              <!-- Submit Button -->
              <button type="submit" class="btn btn-primary">Send Notification</button>
            </form>
          </div>
        </div>
      </div>

      <!-- Delete Notification -->
      <div class="col-md-4">
        <div class="card">
          <div class="card-header">
            <h5 class="card-title">Delete Notification</h5>
          </div>
          <div class="card-body pt-0">
            <form method="POST" action="?action=delete" id="deleteNotificationForm">
              <% if(alert.status === "error" && alert.section === "delete") { %>
              <div class="alert alert-danger alert-dismissible" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                <div class="alert-message">
                  <strong>Error!</strong> <%- alert.message %>
                </div>
              </div>
              <% } %>
              <% if(alert.status === "success" && alert.section === "delete") { %>
              <div class="alert alert-success alert-dismissible" role="alert">
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                <div class="alert-message pr-5">
                  <strong>Success!</strong> <%- alert.message %>
                </div>
              </div>
              <% } %>

              <% if(allNotifications.length > 0) { %>
              <!-- Search and Select Controls -->
              <div class="mb-3">
                <input type="text" class="form-control mb-2" id="deleteNotificationSearch" placeholder="Search notifications...">
                <div class="d-flex align-items-center gap-3">
                  <small class="text-muted"><span id="selectedDeleteCount">0</span> selected</small>
                  <a href="#" id="selectAllDelete" class="small">Select All</a>
                  <a href="#" id="deselectAllDelete" class="small">Deselect All</a>
                </div>
              </div>

              <!-- Notification Checkboxes -->
              <div class="border rounded p-2 mb-3" style="max-height:250px;overflow-y:auto;" id="deleteNotificationList">
                <% allNotifications.forEach((notification) => { %>
                <div class="delete-notification-item form-check py-1 px-2 rounded" data-search="<%= notification.title.toLowerCase() %>">
                  <input class="form-check-input delete-notification-checkbox" type="checkbox" name="notifications" value="<%= notification.id %>" id="delete-notif-<%= notification.id %>">
                  <label class="form-check-label w-100" for="delete-notif-<%= notification.id %>" style="cursor:pointer;">
                    <strong><%= notification.title %></strong>
                    <span class="badge bg-info ms-1" style="font-size:0.7em;"><%= audienceLabels[notification.targetAudience] || 'Legacy' %></span>
                  </label>
                </div>
                <% }) %>
                <div id="deleteNoResults" class="text-muted text-center py-2" style="display:none;">No notifications found</div>
              </div>
              <% } else { %>
              <p class="text-muted">No notifications available to delete.</p>
              <% } %>

              <!-- Submit Button -->
              <button type="submit" class="btn btn-danger" <%= allNotifications.length <= 0 ? "disabled" : "" %>>Delete Selected</button>
            </form>
          </div>
        </div>
      </div>
    </div>

    <!-- Notifications Listing -->
    <div class="row">
      <div class="col-md-12">
        <div class="card">
          <div class="card-header">
            <h5 class="card-title">Sent Notifications</h5>
          </div>
          <div class="card-body">
            <div class="table-responsive">
              <table id="notificationsTable" class="datatable table table-striped table-bordered" style="width:100%">
                <thead>
                  <tr>
                    <th>Title</th>
                    <th>Message</th>
                    <th>Audience</th>
                    <th>Recipients</th>
                    <th>Date Created</th>
                  </tr>
                </thead>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>

  </div>
</main>

<script>
  const userTypeSelect = document.getElementById("userType");
  const studentWrapper = document.getElementById("studentSelectWrapper");
  const aspirantWrapper = document.getElementById("aspirantSelectWrapper");
  const teacherWrapper = document.getElementById("teacherSelectWrapper");

  // Toggle visibility based on recipient type
  userTypeSelect.addEventListener("change", function () {
    const value = this.value;
    studentWrapper.style.display = "none";
    aspirantWrapper.style.display = "none";
    teacherWrapper.style.display = "none";
    // Uncheck all when switching types
    document.querySelectorAll(".student-checkbox, .aspirant-checkbox, .teacher-checkbox").forEach(cb => cb.checked = false);
    updateCount("student");
    updateCount("aspirant");
    updateCount("teacher");

    if (value === "specific-students") {
      studentWrapper.style.display = "block";
    } else if (value === "specific-aspirants") {
      aspirantWrapper.style.display = "block";
    } else if (value === "specific-teachers") {
      teacherWrapper.style.display = "block";
    }
  });

  // Searchable list filtering
  function setupSearch(inputId, listId, noResultsId) {
    const input = document.getElementById(inputId);
    const list = document.getElementById(listId);
    const noResults = document.getElementById(noResultsId);
    if (!input || !list) return;

    input.addEventListener("input", function () {
      const query = this.value.toLowerCase().trim();
      const items = list.querySelectorAll(".searchable-item");
      let visibleCount = 0;
      items.forEach(item => {
        const match = item.dataset.search.includes(query);
        item.style.display = match ? "" : "none";
        if (match) visibleCount++;
      });
      if (noResults) noResults.style.display = visibleCount === 0 ? "" : "none";
    });
  }

  setupSearch("studentSearch", "studentList", "studentNoResults");
  setupSearch("aspirantSearch", "aspirantList", "aspirantNoResults");
  setupSearch("teacherSearch", "teacherList", "teacherNoResults");

  // Selection counter
  function updateCount(type) {
    const count = document.querySelectorAll("." + type + "-checkbox:checked").length;
    const el = document.getElementById(type + "SelectedCount");
    if (el) el.textContent = count;
  }

  document.querySelectorAll(".student-checkbox").forEach(cb => cb.addEventListener("change", () => updateCount("student")));
  document.querySelectorAll(".aspirant-checkbox").forEach(cb => cb.addEventListener("change", () => updateCount("aspirant")));
  document.querySelectorAll(".teacher-checkbox").forEach(cb => cb.addEventListener("change", () => updateCount("teacher")));

  // Select All / Deselect All (only visible items)
  function setupSelectAll(selectAllId, deselectAllId, checkboxClass, type) {
    const selectAll = document.getElementById(selectAllId);
    const deselectAll = document.getElementById(deselectAllId);
    if (selectAll) {
      selectAll.addEventListener("click", function (e) {
        e.preventDefault();
        document.querySelectorAll("." + checkboxClass).forEach(cb => {
          if (cb.closest(".searchable-item").style.display !== "none") cb.checked = true;
        });
        updateCount(type);
      });
    }
    if (deselectAll) {
      deselectAll.addEventListener("click", function (e) {
        e.preventDefault();
        document.querySelectorAll("." + checkboxClass).forEach(cb => cb.checked = false);
        updateCount(type);
      });
    }
  }

  setupSelectAll("studentSelectAll", "studentDeselectAll", "student-checkbox", "student");
  setupSelectAll("aspirantSelectAll", "aspirantDeselectAll", "aspirant-checkbox", "aspirant");
  setupSelectAll("teacherSelectAll", "teacherDeselectAll", "teacher-checkbox", "teacher");

  // Hover effect for items
  document.querySelectorAll(".searchable-item").forEach(item => {
    item.addEventListener("mouseenter", () => item.style.backgroundColor = "#f8f9fa");
    item.addEventListener("mouseleave", () => item.style.backgroundColor = "");
  });

  // Restore state on page load if form was repopulated
  (function () {
    const formData = JSON.parse('<%- JSON.stringify(form || "") %>');
    if (formData && formData.userType) {
      userTypeSelect.value = formData.userType;
      userTypeSelect.dispatchEvent(new Event("change"));
      // Re-check previously selected users
      if (formData.userIds) {
        const ids = Array.isArray(formData.userIds) ? formData.userIds : [formData.userIds];
        ids.forEach(id => {
          const cb = document.getElementById("student-" + id) || document.getElementById("aspirant-" + id) || document.getElementById("teacher-" + id);
          if (cb) cb.checked = true;
        });
        updateCount("student");
        updateCount("aspirant");
        updateCount("teacher");
      }
    }
  })();

  // Delete Notification Section - Search functionality
  const deleteSearchInput = document.getElementById("deleteNotificationSearch");
  const deleteNotificationList = document.getElementById("deleteNotificationList");
  const deleteNoResults = document.getElementById("deleteNoResults");
  const selectedDeleteCount = document.getElementById("selectedDeleteCount");
  const selectAllDelete = document.getElementById("selectAllDelete");
  const deselectAllDelete = document.getElementById("deselectAllDelete");
  const deleteCheckboxes = document.querySelectorAll(".delete-notification-checkbox");

  // Search filter for delete notifications
  if (deleteSearchInput && deleteNotificationList) {
    deleteSearchInput.addEventListener("input", function () {
      const query = this.value.toLowerCase().trim();
      const items = deleteNotificationList.querySelectorAll(".delete-notification-item");
      let visibleCount = 0;
      items.forEach(item => {
        const match = item.dataset.search.includes(query);
        item.style.display = match ? "" : "none";
        if (match) visibleCount++;
      });
      if (deleteNoResults) deleteNoResults.style.display = visibleCount === 0 ? "" : "none";
    });
  }

  // Update selected count for delete section
  function updateDeleteCount() {
    const count = document.querySelectorAll(".delete-notification-checkbox:checked").length;
    if (selectedDeleteCount) selectedDeleteCount.textContent = count;
  }

  deleteCheckboxes.forEach(cb => cb.addEventListener("change", updateDeleteCount));

  // Select All / Deselect All for delete section
  if (selectAllDelete) {
    selectAllDelete.addEventListener("click", function (e) {
      e.preventDefault();
      document.querySelectorAll(".delete-notification-checkbox").forEach(cb => {
        if (cb.closest(".delete-notification-item").style.display !== "none") cb.checked = true;
      });
      updateDeleteCount();
    });
  }

  if (deselectAllDelete) {
    deselectAllDelete.addEventListener("click", function (e) {
      e.preventDefault();
      document.querySelectorAll(".delete-notification-checkbox").forEach(cb => cb.checked = false);
      updateDeleteCount();
    });
  }

  // Hover effect for delete notification items
  document.querySelectorAll(".delete-notification-item").forEach(item => {
    item.addEventListener("mouseenter", () => item.style.backgroundColor = "#f8f9fa");
    item.addEventListener("mouseleave", () => item.style.backgroundColor = "");
  });

  // Restore delete checkboxes on page load if form was repopulated
  (function () {
    const formData = JSON.parse('<%- JSON.stringify(form || "") %>');
    if (formData && formData.notifications) {
      const ids = Array.isArray(formData.notifications) ? formData.notifications : [formData.notifications];
      ids.forEach(id => {
        const cb = document.getElementById("delete-notif-" + id);
        if (cb) cb.checked = true;
      });
      updateDeleteCount();
    }
  })();
</script>

<link rel="stylesheet" href="/DataTables/datatables.min.css">
<link rel="stylesheet" href="/DataTables/responsive.bootstrap.min.css">

<script src="/DataTables/jquery-3.7.1.js"></script>
<script src="/DataTables/bootstrap.bundle.min.js"></script>
<script src="/DataTables/datatables.min.js"></script>
<script src="/DataTables/dataTables.bootstrap5.js"></script>
<script src="/DataTables/dataTables.responsive.min.js"></script>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const table = new DataTable('#notificationsTable', {
      responsive: true,
      serverSide: true,
      ajax: '/api/get-notifications',
      stateSave: true,
      order: [
        [4, 'desc']
      ],
      columns: [
        {
          data: 'title',
        },
        {
          data: 'message',
          render: (data, type, row) => {
            if (type === 'display' && data && data.length > 100) {
              return data.substring(0, 100) + '...';
            }
            return data || '';
          },
        },
        {
          data: 'audienceLabel',
          render: (data, type, row) => {
            return `<span class="badge bg-info">${data}</span>`;
          },
        },
        {
          data: null,
          render: (data, type, row) => {
            if (!row.isSpecific) {
              return '<span class="text-muted">All users in audience</span>';
            }
            if (row.recipientCount === 0) {
              return '<span class="text-muted">No specific recipients</span>';
            }
            
            const recipientPlural = row.recipientCount > 1 ? 's' : '';
            return `<button class="btn btn-sm btn-outline-secondary recipient-toggle" type="button" data-notification-id="${row.id}">${row.recipientCount} recipient${recipientPlural} <i class="fas fa-chevron-down ms-1"></i></button>`;
          },
        },
        {
          data: 'createdAt',
          render: (data, type, row) => {
            if (type === 'display' && data) {
              const date = new Date(data);
              return date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
            }
            return data;
          },
        },
      ],
      createdRow: function(row, data, dataIndex) {
        // Store row data in the row element for easy access
        row.dataset.rowData = JSON.stringify(data);
      }
    });
    
    // Use jQuery event delegation for recipient toggle buttons
    $('#notificationsTable tbody').on('click', '.recipient-toggle', function(e) {
      e.preventDefault();
      e.stopPropagation();
      
      const btn = this;
      const tr = btn.closest('tr');
      const rowData = JSON.parse(tr.dataset.rowData);
      
      // Toggle the button state
      const isExpanded = btn.classList.contains('active');
      
      // Close any other expanded rows first
      document.querySelectorAll('.recipient-toggle.active').forEach(otherBtn => {
        if (otherBtn !== btn) {
          otherBtn.classList.remove('active');
          const otherTr = otherBtn.closest('tr');
          const otherNextRow = otherTr.nextElementSibling;
          if (otherNextRow && otherNextRow.classList.contains('recipient-details-row')) {
            otherNextRow.remove();
          }
          // Reset the button text
          const otherRowData = JSON.parse(otherTr.dataset.rowData);
          const otherPlural = otherRowData.recipientCount > 1 ? 's' : '';
          otherBtn.innerHTML = `${otherRowData.recipientCount} recipient${otherPlural} <i class="fas fa-chevron-down ms-1"></i>`;
        }
      });
      
      if (isExpanded) {
        // Collapse
        btn.classList.remove('active');
        const plural = rowData.recipientCount > 1 ? 's' : '';
        btn.innerHTML = `${rowData.recipientCount} recipient${plural} <i class="fas fa-chevron-down ms-1"></i>`;
        const nextRow = tr.nextElementSibling;
        if (nextRow && nextRow.classList.contains('recipient-details-row')) {
          nextRow.remove();
        }
      } else {
        // Expand
        btn.classList.add('active');
        const plural = rowData.recipientCount > 1 ? 's' : '';
        btn.innerHTML = `${rowData.recipientCount} recipient${plural} <i class="fas fa-chevron-up ms-1"></i>`;
        
        // Build recipient details HTML
        let recipientHtml = '<div class="p-3 bg-light">';
        
        if (rowData.students && rowData.students.length > 0) {
          const studentBadges = rowData.students.map(s => {
            const name = [s.firstName, s.middleName, s.lastName].filter(n => n).join(' ');
            const className = s.className ? ` <span class="text-muted ms-1">(${s.className})</span>` : '';
            return `<span class="badge bg-primary bg-opacity-10 text-primary me-1 mb-1">${name}${className}</span>`;
          }).join('');
          recipientHtml += `<div class="mb-2"><strong class="text-primary"><i class="fas fa-user-graduate me-1"></i> Students (${rowData.students.length}):</strong><div class="ms-3 mt-1">${studentBadges}</div></div>`;
        }
        
        if (rowData.aspirants && rowData.aspirants.length > 0) {
          const aspirantBadges = rowData.aspirants.map(a => {
            const name = [a.firstName, a.middleName, a.lastName].filter(n => n).join(' ');
            const className = a.className ? ` <span class="text-muted ms-1">(${a.className})</span>` : '';
            return `<span class="badge bg-success bg-opacity-10 text-success me-1 mb-1">${name}${className}</span>`;
          }).join('');
          recipientHtml += `<div class="mb-2"><strong class="text-success"><i class="fas fa-user-plus me-1"></i> Aspirants (${rowData.aspirants.length}):</strong><div class="ms-3 mt-1">${aspirantBadges}</div></div>`;
        }
        
        if (rowData.teachers && rowData.teachers.length > 0) {
          const teacherBadges = rowData.teachers.map(t => {
            return `<span class="badge bg-warning bg-opacity-10 text-dark me-1 mb-1">${t.firstName} ${t.lastName} <span class="text-muted ms-1">(${t.email})</span></span>`;
          }).join('');
          recipientHtml += `<div class="mb-0"><strong class="text-warning"><i class="fas fa-chalkboard-teacher me-1"></i> Teachers (${rowData.teachers.length}):</strong><div class="ms-3 mt-1">${teacherBadges}</div></div>`;
        }
        
        recipientHtml += '</div>';
        
        // Insert details row after current row
        const detailsRow = document.createElement('tr');
        detailsRow.className = 'recipient-details-row';
        detailsRow.innerHTML = `<td colspan="5" class="p-0">${recipientHtml}</td>`;
        tr.parentNode.insertBefore(detailsRow, tr.nextSibling);
      }
    });
  });
</script>

